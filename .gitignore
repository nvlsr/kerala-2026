# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Source shapefile vendor dir for map extraction (re-clone from
# https://github.com/datameet/maps when re-running scripts/extract-kerala-map.py)
data/maps-master/

# SHRUG data (Development Data Lab) — licensed CC-BY-NC-SA, redistribution
# restricted. Re-download from https://www.devdatalab.org/shrug_download/
# (free, requires email registration). See docs/narrative-cards/ pipelines
# for which modules to fetch.
data/shrug/

# Working/scratch downloads (raw PDFs, scratch CSVs, etc.) — never commit.
# Files we use for analysis get extracted into versioned data/ siblings;
# the source PDFs are too large + redistribution-iffy.
data/temp/

# OSM Overpass snapshots — re-fetchable via scripts/fetch-osm-pow.ts.
# Snapshot date + coverage stats live in data/raw/osm/README.md.
data/raw/osm/*.json

# Per-POI classified dataset — derivable from data/raw/osm/ + the classify
# script (≈30s). The AC-level aggregate is the canonical committed product.
data/places-of-worship.json

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Generated by scripts/analysis/analyze-subrite-cohorts.ts on each run;
# content is consolidated into docs/narratives/{christian,muslim}.md.
docs/narratives/sub-rite-cohort-analysis.md

__pycache__/
*.pyc
