# Source shapefile vendor dir for map extraction (re-clone from
# https://github.com/datameet/maps when re-running scripts/extract-kerala-map.py)
data/maps-master/

# SHRUG data (Development Data Lab) — licensed CC-BY-NC-SA, redistribution
# restricted. Re-download from https://www.devdatalab.org/shrug_download/
# (free, requires email registration). See docs/narrative-cards/ pipelines
# for which modules to fetch.
data/shrug/

# Working/scratch downloads (raw PDFs, scratch CSVs, etc.) — never commit.
# Files we use for analysis get extracted into versioned data/ siblings;
# the source PDFs are too large + redistribution-iffy.
data/temp/

